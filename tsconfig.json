{
  "compilerOptions": {
    "target": "ESNext",                    // Use ESNext to output the latest JavaScript features
    "module": "ESNext",                    // Output ES modules for compatibility with Node.js
    "moduleResolution": "Node",            // Resolve modules like Node.js does
    "outDir": "./dist",                    // Directory for the compiled JS files
    "rootDir": "./src",                    // Root directory of TypeScript source code
    "strict": true,   
    "allowJs": true,                       // Allow JavaScript files in the compilation
    "esModuleInterop": true,               // Enable interoperability between CommonJS and ES Modules
    "skipLibCheck": true,       
    "sourceMap": true,           // Skip checking of type definitions to speed up compilation
    "forceConsistentCasingInFileNames": true, // Prevent case mismatch in filenames
    "resolveJsonModule": true,     
    "skipDefaultLibCheck": true,        // Enable importing of JSON files as modules (if needed)
    "baseUrl": ".",                        // Base directory to resolve non-relative module imports
    "paths": {
      "*": ["node_modules/*"]              // Use node_modules to resolve third-party dependencies
    }
  },
  "include": [
    "src/**/*"                             // Include all TypeScript files in the src directory
  ],
  "exclude": [
    "node_modules",                        // Exclude node_modules folder
    "dist"                                 // Exclude the dist folder from being compiled
  ]
}
