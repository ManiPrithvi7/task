node_modules/
dist/
data/*.json
data/*.csv

src/Proof-ca/*

# MQTT TLS runtime (env → disk each boot under DATA_DIR)
data/.mqtt-tls/

# Local provisioning CA / serial — never commit (use env or secrets in prod)
data/ca/*.crt
data/ca/*.key
data/ca/*.srl
data/ca/*.bak-*
!data/ca/.gitkeep
.env
*.log
.DS_Store

# NanoMQ broker TLS (never commit private keys)
broker/certs/*.crt
broker/certs/*.key
broker/certs/*.pem
broker/certs/*.csr
broker/certs/*.bak-*
!broker/certs/.gitkeep

# Provisioning Root CA from env (written at startup to src/certs/)
src/certs/*.crt
src/certs/*.key
src/certs/*.srl
!src/certs/.gitkeep

nanomq-broker/

# OpenSSL leftovers / base64 PEM exports (use env vars in prod, not committed files)
*.csr
*.crt.b64
*.key.b64
*.bak-*
