# Example environment configuration
#
# MongoDB Atlas / self-hosted (required for app startup)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/dbname?retryWrites=true&w=majority
# MONGODB_DB_NAME=statsnapp
#
# Optional — defaults tuned for Atlas (DNS + TLS); raise if "Server selection timed out":
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=45000
# MONGODB_CONNECT_TIMEOUT_MS=30000
#
# Validate without starting the server (Mongo wire protocol — not curl):
#   npm run mongo:ping
#
# InfluxDB 2.x — implicit enable: set INFLUXDB_TOKEN (and optionally INFLUXDB_URL).
# Omit INFLUXDB_TOKEN entirely to skip Influx locally.
#
# Default (recommended): disk write-ahead queue under DATA_DIR — startup continues if HTTP health fails;
# points append locally and a background worker batches POSTs (stateless HTTP, no long-lived socket).
# Render: attach a persistent disk on DATA_DIR if you must survive redeploys without losing queued lines.
#
# INFLUXDB_DISK_QUEUE=false   # strict mode: fail startup when /health + buckets API fail (legacy)
# INFLUXDB_DISK_QUEUE_PATH=./data/influx-write-queue.lines   # optional absolute or cwd-relative path
# INFLUXDB_QUEUE_FLUSH_MS=5000
# INFLUXDB_QUEUE_BATCH_MAX=500
# INFLUXDB_QUEUE_MAX_LINES_PER_FILE=100000
#
# Hosted on Render: HTTPS origin only (no :8086 / :10000 in URL — proxy forwards to the container).
# Match DOCKER_INFLUXDB_INIT_* on the Influx service for org/bucket; token must match API access.
#
# INFLUXDB_URL=https://influxdb-rc96.onrender.com
# (alias) INFLUXDB_HOST=https://influxdb-rc96.onrender.com  # used if INFLUXDB_URL is unset
# INFLUXDB_TOKEN=<Influx API token / admin token from setup>
# INFLUXDB_ORG=statsmqtt
# INFLUXDB_BUCKET=metrics
#
# Optional: startup REST probe timeout (GET /api/v2/buckets). Falls back to INFLUXDB_FLUX_PROBE_TIMEOUT_MS if unset.
# INFLUXDB_API_PROBE_TIMEOUT_MS=20000
#
# Idle / cold start (e.g. Render): retry /health and buckets (default 3 attempts, 2.5s apart; loopback uses 1 attempt).
# INFLUXDB_HEALTH_RETRIES=3
# INFLUXDB_HEALTH_RETRY_DELAY_MS=3000
# INFLUXDB_HEALTH_TIMEOUT_MS=25000
#
# Local default when both INFLUXDB_URL and INFLUXDB_HOST are omitted: http://localhost:8086
#
# Redis (Upstash)
# - Optional in development: if unset, provisioning tokens fall back to in-memory storage.
# - Required in production: app will refuse to start without it.
#
# IMPORTANT: Must use TLS.
REDIS_URL=rediss://default:your_password@your-upstash-instance.upstash.io:6379
#
# Instagram — poller runs when REDIS_URL is connected. Graph fetches default to THIS SERVER unless you offload:
#
# Optional serverless (burst / scale-out): when set, ALL poller fetches POST to this URL.
# If unset, the app calls Instagram Graph API directly. Credentials: Redis proof.mqtt:device:{id}
# and active-devices.json are filled at /active registration from Mongo (Device.userId → Social).
# Aliases: VERCEL_INSTAGRAM_FETCH_URL, VERCEL_INSTAGRAM_FETCH_API_KEY
#
# INSTAGRAM_SERVERLESS_URL=http://localhost:3000/api/instagram/fetch
# INSTAGRAM_SERVERLESS_API_KEY=
# INSTAGRAM_SERVERLESS_TIMEOUT_MS=30000
#
# Serverless POST body: deviceIds, trigger, optional correlation_id (worker loads creds from Redis).
#
# Screen publisher (stats cycle): mock Instagram is OFF by default so `/instagram` is not overwritten
# with fake numbers. Set only for firmware demos without Graph polling:
# STATS_PUBLISHER_MOCK_INSTAGRAM=true
