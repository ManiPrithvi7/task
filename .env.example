# Example environment configuration
#
# InfluxDB 2.x (optional metrics / audit)
# - Hosted on Render: use the HTTPS URL only (proxy forwards to the container port — do not append :8086).
# - Match DOCKER_INFLUXDB_INIT_* on the Influx service: org/bucket/token from setup.
#
# INFLUXDB_ENABLED=true
# INFLUXDB_REQUIRED=true
# INFLUXDB_URL=https://influxdb-rc96.onrender.com
# INFLUXDB_TOKEN=<DOCKER_INFLUXDB_INIT_ADMIN_TOKEN from Render secrets>
# INFLUXDB_ORG=statsmqtt
# INFLUXDB_BUCKET=metrics
#
# Local Docker default URL if unset: http://localhost:8086 — override INFLUXDB_URL for remote.
#
# Redis (Upstash)
# - Optional in development: if unset, provisioning tokens fall back to in-memory storage.
# - Required in production: app will refuse to start without it.
#
# IMPORTANT: Must use TLS.
REDIS_URL=rediss://default:your_password@your-upstash-instance.upstash.io:6379

# InfluxDB 2.x (optional — enable with INFLUXDB_ENABLED=true)
# Startup validates token before connecting; missing token causes immediate failure when required.
# Typical local Docker: map host 8087 → container 8086 → INFLUXDB_URL=http://127.0.0.1:8087
# INFLUXDB_ENABLED=false
# INFLUXDB_URL=http://127.0.0.1:8087
# INFLUXDB_TOKEN=
# INFLUXDB_ORG=statsmqtt
# INFLUXDB_BUCKET=statsmqtt
# INFLUXDB_REQUIRED=false

