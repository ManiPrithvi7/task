# =============================================================================
# Railway — NanoMQ broker (Option B: mTLS via env vars) — RECOMMENDED
# =============================================================================
# Do NOT commit real PEMs or keys. Copy values into Railway → Variables only.
#
# Build/deploy (see broker/RAILWAY.txt):
#   • Root Directory: empty (repo root)
#   • RAILWAY_DOCKERFILE_PATH=broker/Dockerfile  (or use repo railway.json)
#
# Option B — set all three variables below with FULL PEM text (including BEGIN/END lines).
# Do NOT set NANOMQ_DISABLE_TLS (omit it or leave unset).
#
# After deploy: Railway → Networking → TCP Proxy → container port 8883
# =============================================================================

# --- Root CA PEM (same as data/ca/root-ca.crt — public CA that signed broker + client certs) ---
NANOMQ_TLS_CA_CERT="-----BEGIN CERTIFICATE-----
REPLACE_WITH_CONTENT_OF_root-ca.crt
-----END CERTIFICATE-----"

# --- Broker server certificate (same as broker/certs/broker.crt) ---
NANOMQ_TLS_CERT="-----BEGIN CERTIFICATE-----
REPLACE_WITH_CONTENT_OF_broker.crt
-----END CERTIFICATE-----"

# --- Broker private key — SECRET (same as broker/certs/broker.key) ---
# May be BEGIN RSA PRIVATE KEY — paste exactly as in the file.
NANOMQ_TLS_KEY="-----BEGIN PRIVATE KEY-----
REPLACE_WITH_CONTENT_OF_broker.key
-----END PRIVATE KEY-----"

# =============================================================================
# Optional — staging only (plain MQTT 1883, NO mTLS). Do not use with Option B.
# =============================================================================
# NANOMQ_DISABLE_TLS=1

# =============================================================================
# After deploy, note Railway TCP public host:port for your app, e.g.:
#   MQTT_BROKER=xxxx.up.railway.app
#   MQTT_PORT=<external TCP port mapped to 8883>
# If TCP hostname ≠ broker cert CN:
#   MQTT_TLS_SERVERNAME=<CN from broker.crt, e.g. nanomq-broker>
# =============================================================================

# -----------------------------------------------------------------------------
# statsmqtt / Render (NOT on the Railway broker service — set on your Node app)
# -----------------------------------------------------------------------------
#
# MQTT_BROKER=<RAILWAY_TCP_HOST>
# MQTT_PORT=<RAILWAY_TCP_PORT>
# MQTT_TLS_SERVERNAME=<broker cert CN if needed>
# MQTT_TLS_CA_PATH=./data/ca/root-ca.crt
# MQTT_TLS_CLIENT_CERT_PATH=./broker/certs/client.crt
# MQTT_TLS_CLIENT_KEY_PATH=./broker/certs/client.key
#
